{
  "name": "cartoon-reel-workspace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "npm run install:backend",
    "install:frontend": "cd cartoon-reel-frontend && npm install",
    "install:backend": "cd cartoon-reel-backend && npm install",
    "install:all": "npm run install:frontend && npm run install:backend",
    "dev:frontend": "cd cartoon-reel-frontend && npm run dev",
    "dev:backend": "cd cartoon-reel-backend && npm run dev",
    "dev": "concurrently -c \"cyan,magenta\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build-all": "cd cartoon-reel-frontend && npm run build",
    "start": "cd cartoon-reel-backend && node server.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
